---

<section class="py-20 bg-primary text-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,0.1) 35px, rgba(255,255,255,0.1) 70px);"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-white/60 uppercase tracking-widest text-sm mb-4">Our Flagship Service</p>
      <h2 class="font-display text-5xl md:text-6xl lg:text-7xl mb-6">
        New Construction Plumbing
      </h2>
      <p class="text-xl md:text-2xl text-white/80 mb-4 font-light">
        Built right. From the ground up.
      </p>
      <p class="text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        From rough-in to final trim, Daley Plumbing handles every phase of new construction plumbing in Pierce and King County. We work with builders, contractors, and homeowners to keep projects on schedule and up to code.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="/services/new-construction" 
          class="inline-block bg-white text-primary px-8 py-4 font-semibold text-lg hover:bg-secondary transition-all"
        >
          Learn More
        </a>
        <a 
          href="/contact" 
          class="inline-block border-2 border-white/80 text-white px-8 py-4 font-semibold text-lg hover:bg-white hover:text-primary transition-all"
        >
          Work With Us on Your Next Build
        </a>
      </div>
    </div>
  </div>
</section>
