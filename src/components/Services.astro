---
---

<section id="services" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="font-display text-5xl md:text-6xl text-primary mb-4">
        What We Do
      </h2>
      <p class="text-xl text-neutral-600 max-w-2xl mx-auto">
        From new builds to emergency calls — a decade of South Sound plumbing.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <!-- 1. New Construction -->
      <a href="/services/new-construction" class="group bg-secondary p-8 border-2 border-neutral-200 hover:border-primary transition-all">
        <div class="w-14 h-14 bg-primary text-white flex items-center justify-center mb-5">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-2 group-hover:text-accent transition-colors">New Construction</h3>
        <p class="text-neutral-600">
          Our flagship. From rough-in to final trim, we handle every phase of new construction plumbing — on time, on code, on budget.
        </p>
      </a>

      <!-- 2. Remodel & Renovation -->
      <a href="/services/remodel-renovation" class="group bg-secondary p-8 border-2 border-neutral-200 hover:border-primary transition-all">
        <div class="w-14 h-14 bg-primary text-white flex items-center justify-center mb-5">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-2 group-hover:text-accent transition-colors">Remodel & Renovation</h3>
        <p class="text-neutral-600">
          Updating a kitchen? Redoing a bathroom? We work with your contractor or direct — rerouting, upgrading, and getting it right the first time.
        </p>
      </a>

      <!-- 3. Drain & Sewer -->
      <a href="/services/drain-sewer" class="group bg-secondary p-8 border-2 border-neutral-200 hover:border-primary transition-all">
        <div class="w-14 h-14 bg-primary text-white flex items-center justify-center mb-5">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-2 group-hover:text-accent transition-colors">Drain & Sewer</h3>
        <p class="text-neutral-600">
          Slow drains, backups, sewer line issues — we clear them out and figure out why it happened so it doesn't happen again.
        </p>
      </a>

      <!-- 4. Water Heater -->
      <a href="/services/water-heater" class="group bg-secondary p-8 border-2 border-neutral-200 hover:border-primary transition-all">
        <div class="w-14 h-14 bg-primary text-white flex items-center justify-center mb-5">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-2 group-hover:text-accent transition-colors">Water Heaters</h3>
        <p class="text-neutral-600">
          Tank or tankless, repair or replace — we'll give you a straight answer on what you actually need, not an upsell.
        </p>
      </a>

      <!-- 5. Fixture Installation -->
      <a href="/services/fixture-installation" class="group bg-secondary p-8 border-2 border-neutral-200 hover:border-primary transition-all">
        <div class="w-14 h-14 bg-primary text-white flex items-center justify-center mb-5">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-2 group-hover:text-accent transition-colors">Fixture Installation</h3>
        <p class="text-neutral-600">
          Sinks, faucets, toilets, showers — installed correctly with attention to detail. We bring the right parts the first time.
        </p>
      </a>

      <!-- 6. Emergency Plumbing -->
      <a href="/services/emergency" class="group bg-secondary p-8 border-2 border-neutral-200 hover:border-accent transition-all">
        <div class="w-14 h-14 bg-accent text-white flex items-center justify-center mb-5">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-accent mb-2 group-hover:text-primary transition-colors">Emergency Plumbing</h3>
        <p class="text-neutral-600">
          Burst pipe? Major leak? We pick up the phone and get there fast. No answering service — you get a real plumber.
        </p>
      </a>
    </div>

    <div class="text-center mt-16">
      <p class="text-lg text-neutral-600 mb-6">
        Not sure what you need? Tell us what's going on — we'll figure it out.
      </p>
      <a 
        href="/contact" 
        class="inline-block bg-accent text-white px-8 py-4 font-semibold text-lg hover:bg-accent/90 transition-all shadow-lg"
      >
        Get a Free Estimate
      </a>
    </div>
  </div>
</section>
