---
---

<section class="py-20 bg-gradient-to-br from-secondary via-white to-tan/30">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="font-display text-5xl md:text-6xl text-primary mb-4">
        Why Daley
      </h2>
      <p class="text-xl text-neutral-600 max-w-2xl mx-auto">
        The local alternative to the big guys. No mystery charges. No runaround.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Trust -->
      <div class="bg-white p-8 border-t-4 border-primary shadow-sm">
        <div class="w-12 h-12 bg-primary/10 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-3">Trust</h3>
        <p class="text-neutral-700 leading-relaxed">
          Licensed, insured, a decade of doing it right. We don't hide behind fine print or surprise you with mystery charges. Straight talk, fair price — every time.
        </p>
      </div>

      <!-- Expertise -->
      <div class="bg-white p-8 border-t-4 border-green shadow-sm">
        <div class="w-12 h-12 bg-green/10 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-3">Expertise</h3>
        <p class="text-neutral-700 leading-relaxed">
          New construction is our specialty. We know the code, know the tradespeople, and know how to keep a job site moving. 10 years in the pipes — and counting.
        </p>
      </div>

      <!-- Warmth -->
      <div class="bg-white p-8 border-t-4 border-accent shadow-sm">
        <div class="w-12 h-12 bg-accent/10 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <h3 class="font-display text-2xl text-primary mb-3">Warmth</h3>
        <p class="text-neutral-700 leading-relaxed">
          We live here. We work here. We show up when we say we will and treat your home like it has our name on it. Our name is on the van — every job is personal.
        </p>
      </div>
    </div>
  </div>
</section>
