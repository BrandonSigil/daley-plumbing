---
import Header from './Header.astro';
---

<section id="home" class="relative">
  <Header />

  <div class="relative overflow-hidden pt-28 md:pt-36 lg:pt-44 pb-20 md:pb-28 lg:pb-36">
    <div
      class="absolute inset-0 bg-cover bg-center grayscale"
      style="background-image: url('https://images.unsplash.com/photo-1749532125405-70950966b0e5?q=80&w=3271&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');"
    ></div>
    <div class="absolute inset-0 bg-primary mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-primary/30"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="flex flex-col items-center text-center">
        <div class="mb-8 md:mb-12">
          <img 
            src="/images/DaleyLogo.svg" 
            alt="Daley Plumbing" 
            class="w-80 md:w-[35rem] lg:w-[45rem] h-auto brightness-0 invert"
          />
        </div>

        <div class="flex items-center gap-4 mb-6 md:mb-8">
          <div class="w-12 md:w-20 h-px bg-white/40"></div>
          <p class="text-white/90 text-lg md:text-xl font-light italic tracking-wide">
            Plumber for the People
          </p>
          <div class="w-12 md:w-20 h-px bg-white/40"></div>
        </div>

        <p class="text-white/80 text-base md:text-lg max-w-2xl mb-10 md:mb-14 leading-relaxed">
          Licensed, insured, and built on over a decade of professional experience in the South Sound. We show up when we say we will, do the job right, and treat every project like it has our name on it. Because it does.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a 
            href="tel:2538575064" 
            class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 text-sm md:text-base font-semibold tracking-widest uppercase hover:bg-secondary transition-all duration-300"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            Call (253) 857-5064
          </a>
          <a 
            href="/contact" 
            class="inline-flex items-center gap-3 border-2 border-white/80 text-white px-8 py-4 text-sm md:text-base font-medium tracking-widest uppercase hover:bg-white hover:text-primary transition-all duration-300"
          >
            Get a Free Estimate
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
