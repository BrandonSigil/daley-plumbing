---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<Layout
  title="About Us | Daley Plumbing — Local Plumbers, South Sound WA"
  description="Daley Plumbing was founded on one idea: that a plumbing company could be honest, skilled, and actually a pleasure to work with. Licensed and insured in Pierce County, WA."
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="pt-28 md:pt-36 pb-16 bg-primary text-white">
      <div class="container mx-auto px-4 text-center">
        <h1 class="font-display text-5xl md:text-7xl mb-4">About Daley Plumbing</h1>
        <p class="text-xl text-white/80 max-w-2xl mx-auto">
          Built on 10 years of doing it right.
        </p>
      </div>
    </section>

    <!-- Opening Story -->
    <section class="py-20 bg-secondary">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <blockquote class="text-xl md:text-2xl text-neutral-800 leading-relaxed mb-8 border-l-4 border-primary pl-6">
            Daley Plumbing started with a simple idea: that a plumbing company could be honest, skilled, and actually a pleasure to work with. Founded by a licensed plumber with over a decade in the trade, we've built the kind of business we'd want to hire ourselves — straight talk, fair prices, and work we stand behind.
          </blockquote>
          <p class="text-lg text-neutral-700 leading-relaxed mb-6">
            We got tired of watching customers get overcharged and underserved by big national chains. The kind of outfits that show up with a sales pitch before they even look at the problem. That's not how we work.
          </p>
          <p class="text-lg text-neutral-700 leading-relaxed">
            At Daley Plumbing, the approach is simple: show up when we say we will, give you a straight answer, do the work right, and charge you fairly for it. That's it. No corporate playbook. No upselling. Just good plumbing from people who actually care about the result.
          </p>
        </div>
      </div>
    </section>

    <!-- Founder Section -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <!-- [PLACEHOLDER] Replace with real founder photo -->
          <div class="bg-secondary border-2 border-tan aspect-square flex items-center justify-center">
            <div class="text-center p-8">
              <svg class="w-24 h-24 text-tan mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <p class="text-neutral-500 text-sm italic">Founder photo coming soon</p>
            </div>
          </div>

          <div>
            <h2 class="font-display text-4xl md:text-5xl text-primary mb-6">The Person Behind the Pipes</h2>
            <!-- [PLACEHOLDER] Replace with founder's actual name -->
            <p class="text-lg text-neutral-700 leading-relaxed mb-6">
              Daley Plumbing was founded by a plumber who spent over a decade mastering the trade before building a company around the values that matter: honesty, quality, and showing up when you say you will.
            </p>
            <p class="text-lg text-neutral-700 leading-relaxed mb-6">
              New construction is where we cut our teeth — and where we still do our best work. There's something about building a plumbing system from nothing, getting every joint right, every run sloped perfectly, every inspection passed the first time. That's the standard we bring to every job, big or small.
            </p>
            <div class="bg-secondary p-4 border-l-4 border-primary">
              <!-- [PLACEHOLDER] Insert actual WA State license number -->
              <p class="text-sm text-neutral-600">WA State Licensed Plumber</p>
              <p class="font-semibold text-neutral-800">License #: [To be added]</p>
              <p class="text-sm text-neutral-600 mt-1">Fully licensed and insured</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What "Daley Does It Right" Means -->
    <section class="py-20 bg-gradient-to-br from-secondary via-white to-tan/30">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-16">
            <h2 class="font-display text-4xl md:text-5xl text-primary mb-4">What "Daley Does It Right" Means</h2>
            <p class="text-lg text-neutral-600">It's not a slogan. It's how we run the company.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-8 border-t-4 border-primary shadow-sm">
              <h3 class="font-display text-2xl text-primary mb-3">We Show Up</h3>
              <p class="text-neutral-700 leading-relaxed">
                When we say 8 AM, we mean 8 AM. Respecting your time isn't going above and beyond — it's the baseline. We just actually do it.
              </p>
            </div>
            <div class="bg-white p-8 border-t-4 border-green shadow-sm">
              <h3 class="font-display text-2xl text-primary mb-3">We Talk Straight</h3>
              <p class="text-neutral-700 leading-relaxed">
                No mystery charges. No "well, while we're here..." upsells. We tell you what's wrong, what it costs, and how long it takes. If we wouldn't pay for it at our own house, we won't recommend it at yours.
              </p>
            </div>
            <div class="bg-white p-8 border-t-4 border-accent shadow-sm">
              <h3 class="font-display text-2xl text-primary mb-3">We Do It Right</h3>
              <p class="text-neutral-700 leading-relaxed">
                Code-compliant. Inspected. Built to last. We don't cut corners to save an hour, and we don't use cheap parts to pad margins. The work speaks for itself.
              </p>
            </div>
            <div class="bg-white p-8 border-t-4 border-tan shadow-sm">
              <h3 class="font-display text-2xl text-primary mb-3">We're Here to Stay</h3>
              <p class="text-neutral-700 leading-relaxed">
                We live in the South Sound. We work in the South Sound. Our reputation is the only marketing we need — every job either builds it or breaks it. We choose wisely.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Community Connection -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="font-display text-4xl md:text-5xl text-primary mb-6">Tacoma-Built. South Sound Proud.</h2>
          <p class="text-lg text-neutral-700 leading-relaxed mb-6">
            We're not headquartered somewhere far away with a call center routing your call. We live in Pierce County. We know the neighborhoods. We know what South Sound homes need because we live in them too.
          </p>
          <p class="text-lg text-neutral-700 leading-relaxed mb-8">
            When you hire Daley Plumbing, you're keeping it local. You're working with real tradespeople in your real community. And if you ever see the van around town, feel free to wave.
          </p>
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="py-20 bg-primary text-white">
      <div class="container mx-auto px-4 text-center">
        <h2 class="font-display text-4xl md:text-5xl mb-6">
          Want to work with a company that treats your home like it has our name on it?
        </h2>
        <p class="text-2xl text-white/80 mb-10 italic">It does.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="tel:2244301420" class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 font-semibold text-lg hover:bg-secondary transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            Call (224) 430-1420
          </a>
          <a href="/contact" class="inline-block border-2 border-white/80 text-white px-8 py-4 font-semibold text-lg hover:bg-white hover:text-primary transition-all">
            Get a Free Estimate
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
