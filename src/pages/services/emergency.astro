---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Emergency Plumber in Tacoma, WA | Daley Plumbing | (224) 430-1420"
  description="Plumbing emergency in Tacoma? Burst pipe, major leak, sewer backup — Daley Plumbing responds fast. We pick up the phone. Call (224) 430-1420 now."
>
  <Header />
  <main>
    <!-- Hero - Emergency specific with accent color -->
    <section class="pt-28 md:pt-36 pb-16 bg-accent text-white">
      <div class="container mx-auto px-4 text-center">
        <p class="text-white/80 uppercase tracking-widest text-sm mb-4">We Pick Up the Phone</p>
        <h1 class="font-display text-5xl md:text-7xl mb-4">Emergency Plumbing in Tacoma, WA</h1>
        <p class="text-xl text-white/80 max-w-2xl mx-auto mb-8">
          Burst pipe? Major leak? Sewer backup? Don't wait — call now.
        </p>
        <a href="tel:2244301420" class="inline-flex items-center gap-3 bg-white text-accent px-10 py-5 font-semibold text-xl hover:bg-secondary transition-all">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          Call (224) 430-1420 Now
        </a>
      </div>
    </section>

    <!-- What We Handle -->
    <section class="py-20 bg-secondary">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="font-display text-4xl md:text-5xl text-primary mb-8">When You Call, We Answer</h2>
          <p class="text-lg text-neutral-700 leading-relaxed mb-6">
            Plumbing emergencies don't wait for business hours, and neither do we. When you call Daley Plumbing with an emergency, you get a real plumber on the phone — not a recording, not an answering service, not a callback in the morning.
          </p>
          <p class="text-lg text-neutral-700 leading-relaxed">
            We're based in the South Sound, which means we can get to most locations in Tacoma and Pierce County fast. We'll walk you through immediate steps over the phone while we're on the way.
          </p>
        </div>
      </div>
    </section>

    <!-- Emergency Types -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="font-display text-4xl md:text-5xl text-primary mb-12 text-center">Common Plumbing Emergencies</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-secondary p-6 border-l-4 border-accent">
              <h3 class="font-display text-xl text-primary mb-2">Burst or Broken Pipes</h3>
              <p class="text-neutral-700 text-sm">Shut off the main water valve if you can. We'll get there fast to stop the damage and make the repair.</p>
            </div>
            <div class="bg-secondary p-6 border-l-4 border-accent">
              <h3 class="font-display text-xl text-primary mb-2">Major Water Leaks</h3>
              <p class="text-neutral-700 text-sm">Ceiling dripping? Water pooling where it shouldn't? These get worse by the minute. Call us immediately.</p>
            </div>
            <div class="bg-secondary p-6 border-l-4 border-accent">
              <h3 class="font-display text-xl text-primary mb-2">Sewer Backup</h3>
              <p class="text-neutral-700 text-sm">Sewage coming up through drains is a health hazard. Stop using water and call — we'll clear the blockage and find the cause.</p>
            </div>
            <div class="bg-secondary p-6 border-l-4 border-accent">
              <h3 class="font-display text-xl text-primary mb-2">No Hot Water</h3>
              <p class="text-neutral-700 text-sm">Water heater failure, especially in winter, can't wait. We diagnose and repair — or replace if needed — fast.</p>
            </div>
            <div class="bg-secondary p-6 border-l-4 border-accent">
              <h3 class="font-display text-xl text-primary mb-2">Overflowing Toilet</h3>
              <p class="text-neutral-700 text-sm">Turn off the water supply at the base of the toilet. If it won't stop, call us. We'll handle the mess and the fix.</p>
            </div>
            <div class="bg-secondary p-6 border-l-4 border-accent">
              <h3 class="font-display text-xl text-primary mb-2">Gas Line Issues</h3>
              <p class="text-neutral-700 text-sm">If you smell gas, leave the house and call your gas company first. Then call us for the plumbing repair once it's safe.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Daley for Emergencies -->
    <section class="py-20 bg-gradient-to-br from-secondary via-white to-tan/30">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="font-display text-4xl md:text-5xl text-primary mb-8">Why Call Daley</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
            <div>
              <h3 class="font-display text-xl text-primary mb-2">Real Person Answers</h3>
              <p class="text-neutral-700 text-sm leading-relaxed">No phone tree. No callback queue. You get a plumber who can help you right now — including over-the-phone triage while we're en route.</p>
            </div>
            <div>
              <h3 class="font-display text-xl text-primary mb-2">Local & Fast</h3>
              <p class="text-neutral-700 text-sm leading-relaxed">We're based in Tacoma. We don't have to drive across the metro area. In most cases, we can be at your door within the hour.</p>
            </div>
            <div>
              <h3 class="font-display text-xl text-primary mb-2">Honest Pricing</h3>
              <p class="text-neutral-700 text-sm leading-relaxed">Emergency doesn't mean extortion. We charge fairly even when it's 10 PM. You'll know the cost before we start any work.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cities -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 text-center">
        <h2 class="font-display text-3xl md:text-4xl text-primary mb-8">Emergency Service Area</h2>
        <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
          {['Tacoma', 'Federal Way', 'Puyallup', 'Lakewood', 'Gig Harbor', 'Bonney Lake', 'Spanaway', 'University Place', 'Fife', 'Sumner', 'Auburn'].map(city => (
            <span class="bg-secondary px-4 py-2 text-neutral-700 font-medium border border-neutral-200">{city}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Big CTA -->
    <section class="py-20 bg-accent text-white">
      <div class="container mx-auto px-4 text-center">
        <h2 class="font-display text-5xl md:text-6xl mb-6">Don't Wait. Call Now.</h2>
        <p class="text-xl text-white/80 max-w-xl mx-auto mb-10">
          Every minute counts with a plumbing emergency. We pick up, we respond fast, and we fix it right.
        </p>
        <a href="tel:2244301420" class="inline-flex items-center gap-3 bg-white text-accent px-10 py-5 font-semibold text-xl hover:bg-secondary transition-all">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          (224) 430-1420
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
