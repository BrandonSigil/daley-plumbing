---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact Us | Daley Plumbing | (224) 430-1420"
  description="Get a free estimate from Daley Plumbing. Licensed local plumbers serving Tacoma and the South Sound. Call (224) 430-1420 or fill out our online form."
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="pt-28 md:pt-36 pb-16 bg-primary text-white">
      <div class="container mx-auto px-4 text-center">
        <h1 class="font-display text-5xl md:text-7xl mb-4">Get In Touch</h1>
        <p class="text-xl text-white/80 max-w-2xl mx-auto mb-8">
          Tell us what you've got going on. No pressure — just straight answers.
        </p>
        <a href="tel:2244301420" class="inline-flex items-center gap-3 bg-white text-primary px-10 py-5 font-semibold text-xl hover:bg-secondary transition-all">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          (224) 430-1420
        </a>
      </div>
    </section>

    <!-- Contact Info + Form -->
    <section class="py-20 bg-secondary">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-7xl mx-auto">
          <!-- Left: Info -->
          <div>
            <h2 class="font-display text-3xl md:text-4xl text-primary mb-8">How to Reach Us</h2>
            <div class="space-y-8">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-primary/10 flex items-center justify-center">
                  <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-display text-xl text-primary mb-1">Phone</p>
                  <a href="tel:2244301420" class="text-neutral-700 hover:text-primary transition-colors text-lg font-medium">(224) 430-1420</a>
                  <p class="text-neutral-600 text-sm">We pick up — no answering service</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-primary/10 flex items-center justify-center">
                  <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-display text-xl text-primary mb-1">Email</p>
                  <a href="mailto:nate@daleyplumbing.com" class="text-neutral-700 hover:text-primary transition-colors break-all">nate@daleyplumbing.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-primary/10 flex items-center justify-center">
                  <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-display text-xl text-primary mb-1">Service Area</p>
                  <p class="text-neutral-700">Pierce County & South King County, WA</p>
                  <p class="text-neutral-600 text-sm">Tacoma, Federal Way, Puyallup, Lakewood, Gig Harbor, Bonney Lake, Spanaway, University Place, Fife, Sumner, Auburn, Milton, Edgewood</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-primary/10 flex items-center justify-center">
                  <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-display text-xl text-primary mb-1">Business Hours</p>
                  <p class="text-neutral-700">Monday – Friday: 7:00 AM – 6:00 PM</p>
                  <p class="text-neutral-700">Saturday: 8:00 AM – 4:00 PM</p>
                  <p class="text-neutral-700">Sunday: Emergency calls only</p>
                </div>
              </div>
            </div>

            <div class="mt-10 bg-accent/10 border-l-4 border-accent p-6">
              <h3 class="font-display text-xl text-primary mb-2">Plumbing Emergency?</h3>
              <p class="text-neutral-700 mb-4">Burst pipe? Major leak? Don't wait — call now.</p>
              <a href="tel:2244301420" class="inline-block bg-accent text-white px-6 py-3 font-semibold hover:bg-accent/90 transition-colors">
                Call Now: (224) 430-1420
              </a>
            </div>
          </div>

          <!-- Right: Form -->
          <div class="bg-white p-8 shadow-sm">
            <h2 class="font-display text-3xl text-primary mb-2">Request a Free Estimate</h2>
            <p class="text-neutral-600 text-sm mb-6">No obligation. We'll get back to you within one business day.</p>
            <!-- Wire this form to Netlify Forms, Formspree, or your preferred handler -->
            <form class="space-y-5" name="contact-page" method="POST">
              <div>
                <label for="cp-name" class="block text-sm font-medium text-neutral-700 mb-2">Name</label>
                <input type="text" id="cp-name" name="name" required class="w-full px-4 py-3 border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="Your name" />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="cp-phone" class="block text-sm font-medium text-neutral-700 mb-2">Phone</label>
                  <input type="tel" id="cp-phone" name="phone" required class="w-full px-4 py-3 border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="(253) 555-0000" />
                </div>
                <div>
                  <label for="cp-email" class="block text-sm font-medium text-neutral-700 mb-2">Email</label>
                  <input type="email" id="cp-email" name="email" class="w-full px-4 py-3 border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="your@email.com" />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="cp-city" class="block text-sm font-medium text-neutral-700 mb-2">City</label>
                  <select id="cp-city" name="city" class="w-full px-4 py-3 border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all">
                    <option value="">Select your city...</option>
                    <option value="tacoma">Tacoma</option>
                    <option value="federal-way">Federal Way</option>
                    <option value="puyallup">Puyallup</option>
                    <option value="lakewood">Lakewood</option>
                    <option value="gig-harbor">Gig Harbor</option>
                    <option value="bonney-lake">Bonney Lake</option>
                    <option value="spanaway">Spanaway</option>
                    <option value="university-place">University Place</option>
                    <option value="fife">Fife</option>
                    <option value="sumner">Sumner</option>
                    <option value="auburn">Auburn</option>
                    <option value="milton-edgewood">Milton / Edgewood</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div>
                  <label for="cp-service" class="block text-sm font-medium text-neutral-700 mb-2">Service Needed</label>
                  <select id="cp-service" name="service" class="w-full px-4 py-3 border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all">
                    <option value="">Select a service...</option>
                    <option value="new-construction">New Construction Plumbing</option>
                    <option value="remodel">Remodel & Renovation</option>
                    <option value="drain-sewer">Drain & Sewer</option>
                    <option value="water-heater">Water Heater</option>
                    <option value="fixture">Fixture Installation</option>
                    <option value="emergency">Emergency Plumbing</option>
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>
              <div>
                <label for="cp-message" class="block text-sm font-medium text-neutral-700 mb-2">Tell Us What's Going On</label>
                <textarea id="cp-message" name="message" rows="5" class="w-full px-4 py-3 border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none" placeholder="Brief description of your project or issue..."></textarea>
              </div>
              <button type="submit" class="w-full bg-primary text-white px-6 py-4 font-semibold text-lg hover:bg-primary/90 transition-colors">
                Request a Quote — No Pressure
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
