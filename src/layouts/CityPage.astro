---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';

interface ServiceLink {
  title: string;
  href: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  city: string;
  intro: string;
  localDetails: string;
  services: ServiceLink[];
  responseNote?: string;
}

const {
  title,
  description,
  city,
  intro,
  localDetails,
  services,
  responseNote = `We're based in the South Sound, which means fast response times to ${city}. When you call, you get a real plumber — not an answering service.`,
} = Astro.props;
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="pt-28 md:pt-36 pb-16 bg-primary text-white">
      <div class="container mx-auto px-4 text-center">
        <h1 class="font-display text-5xl md:text-7xl mb-4">Plumber in {city}, WA</h1>
        <p class="text-xl text-white/80 max-w-2xl mx-auto mb-8">
          Local plumbers who actually care. Serving {city} and the South Sound.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="tel:2244301420" class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 font-semibold hover:bg-secondary transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            Call (224) 430-1420
          </a>
          <a href="/contact" class="inline-block border-2 border-white/80 text-white px-8 py-4 font-semibold hover:bg-white hover:text-primary transition-all">
            Get a Free Estimate
          </a>
        </div>
      </div>
    </section>

    <!-- Intro + Local Details -->
    <section class="py-20 bg-secondary">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <p class="text-xl text-neutral-800 leading-relaxed mb-6">{intro}</p>
          <p class="text-lg text-neutral-700 leading-relaxed">{localDetails}</p>
          <slot name="extra-content" />
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="font-display text-4xl md:text-5xl text-primary mb-8 text-center">Plumbing Services in {city}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map((svc, i) => (
              <a href={svc.href} class={`bg-secondary p-6 border-l-4 shadow-sm hover:shadow-md transition-shadow group ${i % 3 === 0 ? 'border-primary' : i % 3 === 1 ? 'border-green' : 'border-accent'}`}>
                <h3 class="font-display text-xl text-primary mb-2 group-hover:text-accent transition-colors">{svc.title}</h3>
                <p class="text-neutral-600 text-sm">{svc.description}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Response Time -->
    <section class="py-16 bg-gradient-to-br from-secondary via-white to-tan/30">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-2xl mx-auto">
          <h2 class="font-display text-3xl md:text-4xl text-primary mb-6">Fast, Local Response</h2>
          <p class="text-lg text-neutral-700 leading-relaxed">{responseNote}</p>
        </div>
      </div>
    </section>

    <FinalCTA />
  </main>
  <Footer />
</Layout>
