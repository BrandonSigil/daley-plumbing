---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
}

const {
  title = 'Plumber for the People | Daley Plumbing | Tacoma, WA | (224) 430-1420',
  description = 'Daley Plumbing — licensed, local plumbers serving Tacoma and the South Sound. New construction, remodels, repairs, and emergency plumbing. No runaround. (224) 430-1420',
  image = '/images/DaleyLogo.svg',
  canonicalPath,
} = Astro.props;

const canonicalURL = canonicalPath
  ? new URL(canonicalPath, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

const schema = {
  "@context": "https://schema.org",
  "@type": ["PlumbingService", "LocalBusiness"],
  "name": "Daley Plumbing",
  "slogan": "Plumber for the People",
  "telephone": "(224) 430-1420",
  "email": "nate@daleyplumbing.com",
  "url": "https://daleyplumbing.com",
  "description": description,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Tacoma",
    "addressRegion": "WA",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Tacoma" },
    { "@type": "City", "name": "Federal Way" },
    { "@type": "City", "name": "Puyallup" },
    { "@type": "City", "name": "Lakewood" },
    { "@type": "City", "name": "Gig Harbor" },
    { "@type": "City", "name": "Bonney Lake" },
    { "@type": "City", "name": "Spanaway" },
    { "@type": "City", "name": "University Place" },
    { "@type": "City", "name": "Fife" },
    { "@type": "City", "name": "Sumner" },
    { "@type": "City", "name": "Auburn" },
    { "@type": "City", "name": "Milton" },
    { "@type": "City", "name": "Edgewood" }
  ],
  "priceRange": "$$",
  "openingHours": ["Mo-Fr 07:00-18:00", "Sa 08:00-16:00"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Plumbing Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "New Construction Plumbing" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Remodel & Renovation Plumbing" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Drain & Sewer Services" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Water Heater Services" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fixture Installation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Emergency Plumbing" }}
    ]
  }
};
---

<!doctype html>
<html lang="en" data-theme="daley">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#3563BE" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="bg-secondary text-neutral-900">
    <slot />
  </body>
</html>
